# PostgreSQL (App DB)
POSTGRES_USER=airquality
POSTGRES_PASSWORD=airquality123
POSTGRES_DB=airquality
POSTGRES_PORT=5432

# Airflow metadata DB (same postgres container, different DB)
AIRFLOW_DB=airflow

# Airflow
AIRFLOW_UID=501
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=admin123

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE=postgresql+psycopg2://airquality:airquality123@postgres:5432/mlflow
MLFLOW_ARTIFACT_ROOT=/mlflow-artifacts

# Metabase
MB_DB_TYPE=postgres
MB_DB_HOST=postgres
MB_DB_DBNAME=metabase
MB_DB_USER=airquality
MB_DB_PASS=airquality123
MB_DB_PORT=5432

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# OpenAQ (backfill DAG only)
OPENAQ_API_KEY=your-openaq-api-key

# Sensor Simulator
SENSOR_COUNT=50
EMISSION_INTERVAL_SECONDS=1

# Alerting (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SLACK_WEBHOOK_URL=